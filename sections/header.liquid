{% assign main_menu_linklist = linklists[section.settings.menu].links %}


<nav class="bg-red-400">
  {% comment %} Row 1 {% endcomment %}
  <div class="grid grid-cols-5 mb-7 min-h-[80px] items-center">
    <div class="container col-span-3 bg-amber-300 grid grid-cols-3">
      <div class="logo-name col-span-1 bg-blue-100 mx-auto flex items-center">{{ shop.name }}</div>

      <div class="search col-span-2 bg-purple-200">
        <form action="{{ routes.search_url }}" method="get" class="flex-auto">
          <div class="relative text-gray-500 border">
            <input type="search" name="q" placeholder="Search"
              class="w-full bg-white h-10 px-5 pr-10 text-sm focus:outline-none">
            <button type="submit" class="absolute right-0 top-0 mt-2 mr-2 md:mr-5">
              {% render 'icon-search' %}
            </button>
          </div>
        </form>
      </div>
    </div>
    <div class="container col-span-1 flex items-center justify-center">
      <div class="address flex">
        {% render 'icon-location' %}
        <span class="ml-1">Fashion Center at Pentagon City</span>
      </div>

    </div>

    <div class="container col-span-1">

      <div class="relative inline-block text-left">
        <!-- Button -->
        <button id="accountButton"
          class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
          Account
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Dropdown -->
        <div id="dropdownMenu"
          class="hidden absolute right-0 mt-2 w-48 bg-white border border-gray-200 rounded-md shadow-lg z-50">
          <a href="/account/login" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
            Sign In
          </a>

          <a href="/account/register" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
            Create Account
          </a>
        </div>
      </div>


      <a href="{{ routes.cart_url }}" class="whitespace-nowrap text-base text-gray-500 hover:text-gray-900">
        {% render 'icon-shopping-bag' %}
      </a>




    </div>

  </div>

  {% comment %} Row2 {% endcomment %}
  <div class="container">
    <nav x-data="{ open:false}" class="hidden md:flex space-x-10">

      {% for link in main_menu_linklist %}
      {% if link.links != blank %}
      <div class="relative">
        <button x-on:click="open = ! open" type="button"
          class="inline-flex items-center text-base text-gray-500 hover:text-gray-900">
          {{ link.title }}
          {% render 'icon-dropdown' %}
        </button>
        <!-- STEP 1: Place the div under the button tag -->

        <div x-show="open" @click.away="open = false"
          class="absolute z-10 -ml-5 mt-5 transform px-2 w-screen max-w-md sm:px-0 lg:ml-0 lg:left-1/2 lg:-translate-x-1/2">
          <div class="shadow-lg border ring-black ring-opacity-5 overflow-hidden rounded-lg">
            <div class="relative grid gap-6 bg-white px-5 py-6 sm:gap-8 sm:p-8">
              {% for childlink in link.links %}
              <!-- CREATE THE SUBLINK -->
              <a href="{{ childlink.url }}" class="-m-3 p-3 flex items start rounded-lg hover:bg-gray-100">
                <div class="ml-4">
                  <p class="text-gray-900 text-base font-medium">
                    {{ childlink.title }}
                  </p>
                </div>
              </a>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
      {% else %}
      <div class="relative">
        <a href="{{ link.url }}" class="text-base text-gray-500 hover:text-gray-900">{{ link.title }}</a>
      </div>
      {% endif %}

      {% endfor %}

    </nav>
  </div>
</nav>


<script>
  const button = document.getElementById("accountButton");
  const menu = document.getElementById("dropdownMenu");

  button.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });

  // close dropdown when clicking outside
  document.addEventListener("click", (e) => {
    if (!button.contains(e.target) && !menu.contains(e.target)) {
      menu.classList.add("hidden");
    }
  });
</script>


{% schema %}
{
"name": "Header",
"settings": [
{
"type": "text",
"id":"mobile_menu_title",
"label":"Title",
"default":"Menu",
"info":"Title for Mobile"
},
{
"type": "link_list",
"id":"menu",
"label":"Header Menu",
"default":"main-menu",
}
]
}
{% endschema %}