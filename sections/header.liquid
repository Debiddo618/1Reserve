{% assign main_menu_linklist = linklists[section.settings.menu].links %}

<nav>
  {% comment %} Row 1 {% endcomment %}
  <div class="grid grid-cols-5 mb-7 min-h-[80px] items-center">

    <!-- LOGO + SEARCH -->
    <div class="container col-span-3 grid grid-cols-3">
      <div class="logo-name col-span-1 mx-auto flex items-center">
        {{ shop.name }}
      </div>

      <div class="search col-span-2">
        <form action="{{ routes.search_url }}" method="get" class="flex-auto">
          <div class="relative text-gray-500 border rounded-sm">
            <input type="search" name="q" placeholder="Search"
              class="w-full bg-white h-10 px-5 pr-10 text-sm focus:outline-none">

            <button type="submit" class="absolute right-0 top-0 mt-2 mr-2 md:mr-5">
              {% render 'icon-search' %}
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- LOCATION -->
    <div class="col-span-1 flex items-center justify-center relative">

      <div class="address flex items-center cursor-pointer" id="addressToggle">
        {% render 'icon-location' %}
        <span class="ml-1">Pentagon City</span>

        <!-- ICON (FLIPS) -->
        <span id="addressIcon"
          class="ml-1 transition-transform duration-200">
          {% render 'icon-dropdown' %}
        </span>
      </div>

      <div id="addressDropdown"
        class="hidden absolute top-full mt-2 bg-white rounded-lg drop-shadow-lg p-2 z-50 ml-7">
        <div class="px-3 py-2 hover:bg-gray-100 cursor-pointer font-bold">Fashion Center At Pentagon City</div>
        <div class="px-3 py-2 hover:bg-gray-100 cursor-pointer">1100 S Hayes St Suite M10, Arlington, VA 22202</div>

      </div>

    </div>

    <!-- ACCOUNT + CART -->
    <div class="col-span-1 flex justify-center items-center relative">

      <!-- ACCOUNT -->
      <button id="accountButton" class="mx-2">
        {% render 'icon-account' %}
      </button>

      <div id="accountMenu"
        class="hidden absolute right-0 top-full mt-2 w-48 bg-white border border-gray-200 rounded-md shadow-lg z-50">
        <a href="/account/login" class="block px-4 py-2 text-sm hover:bg-gray-100">
          Sign In
        </a>
        <a href="/account/register" class="block px-4 py-2 text-sm hover:bg-gray-100">
          Create Account
        </a>
      </div>

      <!-- CART -->
      <a href="{{ routes.cart_url }}" class="ml-4">
        {% render 'icon-shopping-bag' %}
      </a>

    </div>

  </div>

  {% comment %} Row 2 {% endcomment %}
  <div class="container">
    <nav class="hidden md:flex space-x-10">

      {% for link in main_menu_linklist %}
        {% if link.links != blank %}
          <div class="relative">

            <button type="button"
              class="inline-flex items-center text-base text-gray-500 hover:text-gray-900"
              onclick="toggleMenu(this)">
              {{ link.title }}
              {% render 'icon-dropdown' %}
            </button>

            <div class="hidden absolute z-10 mt-4 bg-white shadow-lg rounded-lg p-4 min-w-[200px]">
              {% for childlink in link.links %}
                <a href="{{ childlink.url }}"
                   class="block px-3 py-2 hover:bg-gray-100 rounded">
                  {{ childlink.title }}
                </a>
              {% endfor %}
            </div>

          </div>
        {% else %}
          <a href="{{ link.url }}"
             class="text-base text-gray-500 hover:text-gray-900">
            {{ link.title }}
          </a>
        {% endif %}
      {% endfor %}

    </nav>
  </div>
</nav>

<script>
  // ---------------- ACCOUNT DROPDOWN ----------------
  const accountButton = document.getElementById("accountButton");
  const accountMenu = document.getElementById("accountMenu");

  accountButton.addEventListener("click", (e) => {
    e.stopPropagation();
    accountMenu.classList.toggle("hidden");
  });

  // ---------------- ADDRESS DROPDOWN + ICON FLIP ----------------
  const addressToggle = document.getElementById("addressToggle");
  const addressDropdown = document.getElementById("addressDropdown");
  const addressIcon = document.getElementById("addressIcon");

  addressToggle.addEventListener("click", (e) => {
    e.stopPropagation();

    addressDropdown.classList.toggle("hidden");
    addressIcon.classList.toggle("rotate-180");
  });

  // ---------------- CLOSE ON OUTSIDE CLICK ----------------
  document.addEventListener("click", () => {
    accountMenu.classList.add("hidden");
    addressDropdown.classList.add("hidden");
    addressIcon.classList.remove("rotate-180");
    closeAllMenus();
  });

  // ---------------- NAV DROPDOWN (ROW 2) ----------------
  function toggleMenu(button) {
    const menu = button.nextElementSibling;
    menu.classList.toggle("hidden");
  }
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "mobile_menu_title",
      "label": "Title",
      "default": "Menu",
      "info": "Title for Mobile"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Header Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}